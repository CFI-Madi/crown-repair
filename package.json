{
  "name": "crown-repair",
  "version": "0.0.1",
  "private": true,
  "description": "Crown Repair — premium phone and device repair marketplace for the Charlotte metro.",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,md}\" \"*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,css,md}\" \"*.{ts,tsx,js,jsx,json,md}\"",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate:dev": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:migrate:reset": "dotenv -e .env.local -- prisma migrate reset",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:push": "dotenv -e .env.local -- prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@sentry/nextjs": "^10.52.0",
    "@stripe/stripe-js": "^9.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "inngest": "^4.4.0",
    "lucide-react": "^0.460.0",
    "next": "^15.0.0",
    "posthog-js": "^1.373.2",
    "posthog-node": "^5.33.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.1.1",
    "tailwind-merge": "^2.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "_comment": "Build script approvals also live in pnpm-workspace.yaml for pnpm 11+ compatibility.",
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
