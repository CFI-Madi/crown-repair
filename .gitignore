# ---------------------------------------------------------------------------
# Environment variables — SECURITY CRITICAL
# Never commit any .env file. Only .env.local.example is allowed.
# ---------------------------------------------------------------------------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.*.local
.env.*

# Explicitly allow the example file (which contains no real secrets)
!.env.local.example
!.env.example

