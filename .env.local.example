# ============================================================================
# Crown Repair — environment variable reference
# ----------------------------------------------------------------------------
# Copy this file to .env.local and fill in real values for local development.
# NEVER commit .env.local — it is gitignored.
#
# Every value below is a placeholder. Real values come from the respective
# service dashboards (created during their associated Phase 0 checkpoint).
# ============================================================================


# ----- Application ----------------------------------------------------------
# Environment tag — used by Sentry, PostHog, and feature-flag scopes.
# Local dev: development | Vercel preview: preview | Vercel prod: production
NEXT_PUBLIC_APP_ENV=development


# ----- Database — Neon Postgres (Checkpoint C) ------------------------------
# Two URLs are required:
#   DATABASE_URL: pooled connection (used by the app at runtime)
#   DIRECT_DATABASE_URL: direct connection (used by Prisma migrations only)
# Get these from Neon dashboard → Connection Details.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:password@host/db?sslmode=require


# ----- Sentry (Checkpoint D) ------------------------------------------------
# Sentry DSN — public, OK to expose to client.
SENTRY_DSN=https://placeholder@o0.ingest.sentry.io/0
# Sentry auth token — used by build-time source-map upload. Server-only.
SENTRY_AUTH_TOKEN=placeholder_sentry_auth_token


# ----- PostHog (Checkpoint D) -----------------------------------------------
# PostHog project API key — public.
NEXT_PUBLIC_POSTHOG_KEY=phc_placeholder_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com


# ----- Inngest (Checkpoint D) -----------------------------------------------
# Inngest event key + signing key. Both are server-only.
INNGEST_EVENT_KEY=placeholder_inngest_event_key
INNGEST_SIGNING_KEY=signkey-prod-placeholder


# ----- Stripe Connect — test mode (Checkpoint D) ----------------------------
# Test-mode keys for Phase 0. Live-mode keys come later, after LLC formation.
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_CONNECT_CLIENT_ID=ca_placeholder_connect_client_id
# Webhook signing secret — wired in Phase 0.5 when webhooks are added.
# STRIPE_WEBHOOK_SECRET=whsec_placeholder


# ============================================================================
# DEFERRED — not used in Phase 0; documented here for the future.
# Do NOT add these to .env.local until the corresponding Phase 0.5 task starts.
# ============================================================================

# ----- Clerk (Phase 0.5 Track A) --------------------------------------------
# CLERK_PUBLISHABLE_KEY=pk_test_placeholder
# CLERK_SECRET_KEY=sk_test_placeholder
# CLERK_WEBHOOK_SECRET=whsec_placeholder

# ----- Resend (Phase 0.5 Track A) -------------------------------------------
# RESEND_API_KEY=re_placeholder
# RESEND_WEBHOOK_SECRET=placeholder

# ----- Twilio (Phase 0.5 Track A) -------------------------------------------
# TWILIO_ACCOUNT_SID=AC_placeholder
# TWILIO_AUTH_TOKEN=placeholder
# TWILIO_MESSAGING_SERVICE_SID=MG_placeholder

# ----- Google Maps Platform (Phase 0.5 Track B) -----------------------------
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza_placeholder
# GOOGLE_MAPS_SERVER_KEY=AIza_server_placeholder
